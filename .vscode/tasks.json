{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "buildFlappyBirdDebug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Windows/FlappyBird.Windows.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "buildFlappyBirdRelease",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Windows/FlappyBird.Windows.csproj",
                "--configuration",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}