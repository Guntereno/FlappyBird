{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean Intermediates",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "Get-ChildItem -Recurse -Directory | Where-Object { $_.Name -in @(''bin'',''obj'') } | Remove-Item -Recurse -Force; dotnet clean"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Windows|Debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Windows/FlappyBird.Windows.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Windows|Release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Windows/FlappyBird.Windows.csproj",
                "--configuration",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Android|Debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Android/FlappyBird.Android.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Android|Release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/FlappyBird.Android/FlappyBird.Android.csproj",
                "--configuration",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}